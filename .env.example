# Supabase project ID
VITE_SUPABASE_PROJECT_ID=
# Supabase publishable key for frontend authentication
VITE_SUPABASE_PUBLISHABLE_KEY=
# Supabase project URL
VITE_SUPABASE_URL=

# PlantBot agent URL (the Node.js agent server)
VITE_AGENT_URL=http://localhost:3001

# GitHub Models API key — used by both the frontend (future direct calls) and the agent server
VITE_GITHUB_MODELS_API_KEY=
