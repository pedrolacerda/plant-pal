# Supabase project identifier
VITE_SUPABASE_PROJECT_ID=

# Supabase public API key for client-side authentication
VITE_SUPABASE_PUBLISHABLE_KEY=

# Supabase project URL
VITE_SUPABASE_URL=

# GitHub Models API key for AI model access
VITE_GITHUB_MODELS_API_KEY=

# Agent service URL
VITE_AGENT_URL=

# VAPID public key for push notifications
VITE_VAPID_PUBLIC_KEY=

# Supabase service role key — ONLY needed for the backfill script (scripts/backfill-plant-details.ts)
# Never expose this key in the frontend or commit it to source control
SUPABASE_SERVICE_ROLE_KEY=
