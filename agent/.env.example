# PlantBot agent server configuration
# Copy this file to .env and fill in the values

# GitHub Models API key (same key used by Supabase Edge Functions)
GITHUB_MODELS_API_KEY=your_github_models_api_key_here

# Shared secret for validating requests from the frontend.
# Set this to the same value as VITE_GITHUB_MODELS_API_KEY in the frontend .env.
# Leave blank to disable auth (development only).
AGENT_API_KEY=

# Port the server listens on (default: 3001)
PORT=3001

# Frontend origin allowed by CORS
ALLOWED_ORIGIN=http://localhost:8080
